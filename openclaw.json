  {
    "models": {
      "mode": "merge",
      "providers": {
        "custom-provider": {
          "baseUrl": "请改成你的模型接口地址",
          "apiKey": "请改成你的模型接口密钥",
          "api": "openai-responses",
          "models": [
            {
              "id": "请改成你的模型ID",
              "name": "请改成你的模型显示名称",
              "reasoning": false,
              "input": [
                "text"
              ],
              "cost": {
                "input": 2.5,
                "output": 15,
                "cacheRead": 0,
                "cacheWrite": 0
              },
              "contextWindow": 400000,
              "maxTokens": 16384
            }
          ]
        }
      }
    },
    "agents": {
      "defaults": {
        "model": {
          "primary": "custom-provider/请改成你的模型ID"
        },
        "models": {
          "custom-provider/请改成你的模型ID": {
            "alias": "请改成你的模型别名"
          }
        },
        "workspace": "请改成你的工作区绝对路径",
        "compaction": {
          "mode": "safeguard",
          "reserveTokens": 100000,
          "reserveTokensFloor": 100000
        },
        "thinkingDefault": "high",
        "maxConcurrent": 4,
        "subagents": {
          "maxConcurrent": 8
        }
      }
    },
    "messages": {
      "ackReactionScope": "group-mentions"
    },
    "commands": {
      "native": "auto",
      "nativeSkills": "auto",
      "restart": true,
      "ownerDisplay": "raw"
    },
    "session": {
      "dmScope": "per-channel-peer"
    },
    "hooks": {
      "internal": {
        "enabled": true,
        "entries": {
          "boot-md": {
            "enabled": false
          },
          "session-memory": {
            "enabled": true
          },
          "command-logger": {
            "enabled": false
          },
          "bootstrap-extra-files": {
            "enabled": false
          }
        }
      }
    },
    "channels": {
      "telegram": {
        "enabled": true,
        "dmPolicy": "pairing",
        "botToken": "请改成你的Telegram机器人Token",
        "groupAllowFrom": [
          "请改成允许触发机器人的Telegram用户ID"
        ],
        "groupPolicy": "allowlist",
        "streaming": "partial"
      }
    },
    "gateway": {
      "port": 18789,
      "mode": "local",
      "bind": "loopback",
      "controlUi": {
        "allowedOrigins": [
          "http://127.0.0.1:18789",
          "http://localhost:18789",
          "http://[::1]:18789"
        ]
      },
      "trustedProxies": [
        "127.0.0.1",
        "::1"
      ],
      "tailscale": {
        "mode": "off",
        "resetOnExit": false
      },
      "nodes": {
        "denyCommands": [
          "camera.snap",
          "camera.clip",
          "screen.record",
          "contacts.add",
          "calendar.add",
          "reminders.add",
          "sms.send"
        ]
      }
    },
    "plugins": {
      "entries": {
        "telegram": {
          "enabled": true
        }
      }
    }
  }

  # 需要注意的地方：

  # - custom-provider 和 请改成你的模型ID 这两个值要保持一致。
  #  它们同时出现在 models.providers、agents.defaults.model.primary、agents.defaults.models 里。
  # - workspace 必须填绝对路径。
  #  Linux 例子：/home/你的用户名/.openclaw/workspace
  #  Windows 例子：C:\\Users\\你的用户名\\.openclaw\\workspace
  # - groupAllowFrom 里要填 Telegram 数字用户 ID，不是 bot 用户名。
  # - 如果你改了 gateway.port，要把 controlUi.allowedOrigins 里的端口一起改掉。
  # - streaming 这里我用了 partial，比 off 更通用。
  #  如果你不想看到流式草稿，可以改成 off。
  #- 如果你要更开放的工具权限，把 tools.profile 从 coding 改回 full。
